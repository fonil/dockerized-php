{
    "name": "fonil/dockerized-php-dev-env",
    "type": "project",
    "license": "MIT",
    "description": "A skeleton to build containerized PHP microservices with Docker (with or without Caddy)",
    "keywords": ["skeleton", "caddy", "php", "cli", "composer", "phpunit", "paratest", "infection", "phpinsights", "php-parallel-lint", "phpstan", "phpunit", "pcov", "bypass-finals"],
    "authors": [
        {
            "name": "Alcides Ramos",
            "email": "info@alcidesrc.com",
            "homepage": "https://alcidesrc.com/"
        }
    ],
    "support": {
        "issues": "https://github.com/fonil/dockerized-php-dev-env/issues",
        "source": "https://github.com/fonil/dockerized-php-dev-env"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "brianium/paratest": "^6.5",
        "dg/bypass-finals": "^1.4",
        "infection/infection": "^0.26.13",
        "nunomaduro/phpinsights": "^2.4",
        "php-parallel-lint/php-console-color": "^1.0",
        "php-parallel-lint/php-console-highlighter": "^1.0",
        "php-parallel-lint/php-parallel-lint": "^1.3",
        "phpstan/phpstan": "^1.8",
        "phpunit/phpunit": "^9.5",
        "slope-it/clock-mock": "^0.3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UnitTests\\": "tests/Unit",
            "Hooks\\": "tests/Hooks"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.1.19"
        },
        "allow-plugins": {
            "infection/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
